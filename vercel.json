{
  "rewrites": [
    { "source": "/api/data/:section", "destination": "/api/data/:section" }
  ],
  "functions": {
    "api/data/*.js": {
      "maxDuration": 10
    },
    "api/notify.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
